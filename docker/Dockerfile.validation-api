FROM python:3.11-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    APP_HOME=/app

WORKDIR ${APP_HOME}

COPY pyproject.toml README.md ./
COPY nexis ./nexis
# Eligibility seed (invalid + blacklist hotkeys) served by the GET endpoints.
# Bake it in as a fallback; bind-mount a maintained copy over /app/eligibility
# in the compose file to serve live updates.
COPY eligibility ./eligibility

# bittensor 10.5.0 brings async-substrate-interface 2.x + cyscale (which
# provides the `scalecodec` namespace). The genuine `scalecodec` package must
# NOT be co-installed — async-substrate-interface 2.x refuses to start if both
# are present. A clean build never pulls it, but guard-uninstall anyway in case
# a transitive dep sneaks it in.
RUN pip install --upgrade pip \
    && pip install . \
    && pip uninstall -y scalecodec 2>/dev/null; pip show cyscale >/dev/null

EXPOSE 8080

# `-u` forces line-buffered stdout/stderr (belt-and-suspenders alongside
# PYTHONUNBUFFERED=1). `--log-level info` ensures startup banner and access
# logs are emitted; without it some uvicorn builds suppress everything until
# the first error.
CMD ["python", "-u", "-m", "uvicorn", \
     "nexis.api.app:create_app", \
     "--factory", \
     "--host", "0.0.0.0", \
     "--port", "8080", \
     "--log-level", "info"]

